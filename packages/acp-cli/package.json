{
  "name": "acp-cli",
  "version": "0.1.0",
  "private": true,
  "description": "ACP operator CLI: thin wrapper over acp-server",
  "type": "module",
  "bin": {
    "acp": "./src/cli.ts"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "acp-admin-store": "*",
    "acp-core": "*",
    "acp-ops-projection": "*",
    "acp-server": "*",
    "@wrkq/client": "latest",
    "agent-action-render": "latest",
    "agent-scope": "latest",
    "chalk": "^5.6.2",
    "cli-kit": "latest",
    "commander": "^14.0.0",
    "gateway-discord": "*",
    "spaces-config": "latest"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "coordination-substrate": "*",
    "typescript": "^5.8.3"
  }
}
