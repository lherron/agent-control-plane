{
  "name": "gateway-ios",
  "version": "0.1.0",
  "private": true,
  "description": "iOS gateway for HRC — exposes a TCP HTTP+WS API for SwiftUI mobile clients",
  "type": "module",
  "bin": {
    "gateway-ios": "./src/main.ts"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "hrc-core": "0.1.0-dev.20260607205738",
    "hrc-sdk": "0.1.0-dev.20260607205738",
    "agent-scope": "0.1.1-dev.20260607205719"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.8.3"
  }
}
