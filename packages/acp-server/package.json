{
  "name": "acp-server",
  "version": "0.1.0",
  "private": true,
  "description": "ACP HTTP surface for workflow tasks, coordination events, and runtime/session seams",
  "type": "module",
  "bin": {
    "acp-server": "./src/cli.ts"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@wrkf/client": "0.1.0",
    "acp-admin-store": "*",
    "acp-conversation": "*",
    "acp-core": "*",
    "acp-ops-projection": "*",
    "acp-interface-store": "*",
    "acp-jobs-store": "*",
    "acp-state-store": "*",
    "agent-scope": "0.1.1-dev.20260611173655",
    "coordination-substrate": "*",
    "hrc-core": "0.1.0-dev.20260612100523",
    "hrc-sdk": "0.1.0-dev.20260612100523",
    "spaces-config": "0.1.1-dev.20260611173655",
    "spaces-runtime": "0.1.1-dev.20260611173655",
    "wrkq-lib": "*"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.8.3"
  }
}
