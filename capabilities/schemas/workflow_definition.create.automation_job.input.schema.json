{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "description": "Body accepted by handleCreateAdminJob. Either trigger or schedule is used; schedule.cron is required when trigger is absent.",
  "required": [
    "agentId",
    "projectId",
    "scopeRef",
    "input"
  ],
  "additionalProperties": true,
  "properties": {
    "agentId": {
      "type": "string",
      "minLength": 1
    },
    "projectId": {
      "type": "string",
      "minLength": 1
    },
    "scopeRef": {
      "type": "string",
      "minLength": 1
    },
    "laneRef": {
      "type": "string",
      "minLength": 1
    },
    "slug": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "schedule": {
      "type": "object",
      "required": [
        "cron"
      ],
      "additionalProperties": true,
      "properties": {
        "cron": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "trigger": {
      "type": "object",
      "additionalProperties": true
    },
    "input": {
      "type": "object",
      "additionalProperties": true
    },
    "output": {
      "type": "object",
      "additionalProperties": true
    },
    "flow": {
      "type": "object",
      "additionalProperties": true
    },
    "disabled": {
      "type": "boolean"
    },
    "actor": {
      "type": "object",
      "required": [
        "kind",
        "id"
      ],
      "additionalProperties": true,
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "human",
            "agent",
            "system"
          ]
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "displayName": {
          "type": "string"
        }
      }
    },
    "idempotencyKey": {
      "type": "string",
      "minLength": 1
    }
  },
  "$id": "provider:acp/workflow_definition.create.automation_job.input.v1"
}
