{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "description": "Path parameter plus profile patch fields accepted by handlePatchAdminAgentProfile.",
  "required": [
    "agentId"
  ],
  "additionalProperties": true,
  "properties": {
    "agentId": {
      "type": "string",
      "minLength": 1
    },
    "displayColor": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^#[0-9a-fA-F]{6}$"
    },
    "monogram": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1,
      "maxLength": 3
    },
    "avatarUrl": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "tagline": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "role": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "defaultModel": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "vibe": {
      "anyOf": [
        {
          "type": "array",
          "maxItems": 16,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80
          }
        },
        {
          "type": "null"
        }
      ]
    },
    "specialties": {
      "anyOf": [
        {
          "type": "array",
          "maxItems": 16,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80
          }
        },
        {
          "type": "null"
        }
      ]
    },
    "actor": {
      "type": "object",
      "required": [
        "kind",
        "id"
      ],
      "additionalProperties": true,
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "human",
            "agent",
            "system"
          ]
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "displayName": {
          "type": "string"
        }
      }
    },
    "idempotencyKey": {
      "type": "string",
      "minLength": 1
    }
  },
  "$id": "provider:acp/agent.patch.profile.input.v1"
}
