{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "description": "Path jobId and patch body accepted by handlePatchAdminJob.",
  "required": [
    "jobId"
  ],
  "additionalProperties": true,
  "properties": {
    "jobId": {
      "type": "string",
      "minLength": 1
    },
    "slug": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "schedule": {
      "type": "object",
      "required": [
        "cron"
      ],
      "additionalProperties": true,
      "properties": {
        "cron": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "trigger": {
      "type": "object",
      "additionalProperties": true
    },
    "input": {
      "type": "object",
      "additionalProperties": true
    },
    "output": {
      "anyOf": [
        {
          "type": "object",
          "additionalProperties": true
        },
        {
          "type": "null"
        }
      ]
    },
    "flow": {
      "type": "object",
      "additionalProperties": true
    },
    "disabled": {
      "type": "boolean"
    },
    "actor": {
      "type": "object",
      "required": [
        "kind",
        "id"
      ],
      "additionalProperties": true,
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "human",
            "agent",
            "system"
          ]
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "displayName": {
          "type": "string"
        }
      }
    },
    "idempotencyKey": {
      "type": "string",
      "minLength": 1
    }
  },
  "$id": "provider:acp/workflow_definition.patch.automation_job.input.v1"
}
