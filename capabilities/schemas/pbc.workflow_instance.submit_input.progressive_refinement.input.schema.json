{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "provider:pbc/workflow_instance.submit_input.progressive_refinement.input.v1",
  "type": "object",
  "description": "Path parameter and body accepted by handlePbcInput.",
  "required": ["taskId", "kind", "idempotencyKey"],
  "additionalProperties": true,
  "properties": {
    "taskId": { "type": "string", "minLength": 1 },
    "kind": { "type": "string", "enum": ["clarification_response", "patch_decision"] },
    "idempotencyKey": { "type": "string", "minLength": 1 },
    "data": { "type": "object", "additionalProperties": true },
    "actor": { "$ref": "#/$defs/actor" }
  },
  "$defs": {
    "actor": {
      "type": "object",
      "required": ["kind", "id"],
      "additionalProperties": true,
      "properties": {
        "kind": { "type": "string", "enum": ["human", "agent", "system"] },
        "id": { "type": "string", "minLength": 1 },
        "displayName": { "type": "string" }
      }
    }
  }
}
