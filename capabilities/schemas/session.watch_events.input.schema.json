{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "description": "Path and query accepted by handleSessionEvents.",
  "required": [
    "sessionId"
  ],
  "additionalProperties": true,
  "properties": {
    "sessionId": {
      "type": "string",
      "minLength": 1
    },
    "fromSeq": {
      "type": "integer",
      "minimum": 1
    },
    "follow": {
      "type": "boolean"
    },
    "generation": {
      "type": "integer",
      "minimum": 0
    },
    "runId": {
      "type": "string",
      "minLength": 1
    }
  },
  "$id": "provider:acp/session.watch_events.input.v1"
}
