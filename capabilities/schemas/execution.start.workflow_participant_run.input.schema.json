{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "description": "Body accepted by handleCreateWorkflowParticipantRun.",
  "required": [
    "taskId",
    "role",
    "idempotencyKey"
  ],
  "additionalProperties": true,
  "properties": {
    "taskId": {
      "type": "string",
      "minLength": 1
    },
    "role": {
      "type": "string",
      "minLength": 1
    },
    "idempotencyKey": {
      "type": "string",
      "minLength": 1
    },
    "actor": {
      "type": "object",
      "required": [
        "kind",
        "id"
      ],
      "additionalProperties": true,
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "human",
            "agent",
            "system"
          ]
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "displayName": {
          "type": "string"
        }
      }
    },
    "sessionRef": {
      "anyOf": [
        {
          "type": "object",
          "required": [
            "scopeRef"
          ],
          "additionalProperties": false,
          "properties": {
            "scopeRef": {
              "type": "string",
              "minLength": 1
            },
            "laneRef": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "scopeRef": {
      "type": "string",
      "minLength": 1
    },
    "laneRef": {
      "type": "string",
      "minLength": 1
    },
    "initialPrompt": {
      "type": "string",
      "minLength": 1
    }
  },
  "$id": "provider:acp/execution.start.workflow_participant_run.input.v1"
}
