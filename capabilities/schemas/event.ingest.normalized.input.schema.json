{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "description": "Body accepted by parseAcpWebhookEvent in handleAcpEventWebhook.",
  "required": [
    "event_id",
    "event_seq",
    "source",
    "event"
  ],
  "additionalProperties": true,
  "properties": {
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "event_seq": {
      "type": "integer",
      "minimum": 0
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "event": {
      "type": "object",
      "additionalProperties": true
    },
    "occurred_at": {
      "type": "string",
      "minLength": 1
    },
    "actor": {
      "type": "object",
      "required": [
        "kind",
        "id"
      ],
      "additionalProperties": true,
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "human",
            "agent",
            "system"
          ]
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "displayName": {
          "type": "string"
        }
      }
    },
    "idempotencyKey": {
      "type": "string",
      "minLength": 1
    }
  },
  "$id": "provider:acp/event.ingest.normalized.input.v1"
}
