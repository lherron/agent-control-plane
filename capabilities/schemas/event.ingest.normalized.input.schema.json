{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "description": "Body accepted by parseAcpWebhookEvent in handleAcpEventWebhook.",
  "required": [
    "schema_version",
    "event_id",
    "event_seq",
    "source",
    "event"
  ],
  "additionalProperties": true,
  "properties": {
    "schema_version": {
      "const": 1
    },
    "event_id": {
      "type": "string",
      "pattern": "\\S"
    },
    "event_seq": {
      "type": "integer",
      "minimum": 0
    },
    "source": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9._-]{0,79}$"
    },
    "event": {
      "type": "string",
      "pattern": "\\S"
    },
    "occurred_at": {
      "type": "string"
    },
    "origin": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "actor": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": [
            "human",
            "agent",
            "system"
          ]
        }
      }
    },
    "subject": {
      "type": "object",
      "required": [
        "type"
      ],
      "additionalProperties": true,
      "properties": {
        "type": {
          "type": "string",
          "pattern": "\\S"
        },
        "id": {
          "type": "string"
        }
      }
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    },
    "canonical_event_id": {
      "type": "string",
      "description": "When present, parseAcpWebhookEvent requires this to equal `${source}:${event_id}`."
    }
  },
  "$id": "provider:acp/event.ingest.normalized.input.v1"
}
