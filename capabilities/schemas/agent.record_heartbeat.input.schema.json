{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "description": "Path parameter plus heartbeat fields accepted by handlePutHeartbeat.",
  "required": [
    "agentId"
  ],
  "additionalProperties": true,
  "properties": {
    "agentId": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "note": {
      "type": "string",
      "minLength": 1
    },
    "scopeRef": {
      "type": "string",
      "minLength": 1
    },
    "laneRef": {
      "type": "string",
      "minLength": 1
    },
    "actor": {
      "type": "object",
      "required": [
        "kind",
        "id"
      ],
      "additionalProperties": true,
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "human",
            "agent",
            "system"
          ]
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "displayName": {
          "type": "string"
        }
      }
    },
    "idempotencyKey": {
      "type": "string",
      "minLength": 1
    }
  },
  "$id": "provider:acp/agent.record_heartbeat.input.v1"
}
