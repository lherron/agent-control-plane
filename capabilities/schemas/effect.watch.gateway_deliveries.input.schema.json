{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "description": "Query accepted by handleListFailedDeliveries; status must be failed.",
  "required": [
    "status"
  ],
  "additionalProperties": true,
  "properties": {
    "status": {
      "const": "failed"
    },
    "gatewayId": {
      "type": "string",
      "minLength": 1
    },
    "since": {
      "type": "string",
      "minLength": 1
    },
    "limit": {
      "type": "integer",
      "minimum": 1
    }
  },
  "$id": "provider:acp/effect.watch.gateway_deliveries.input.v1"
}
